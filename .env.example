# Local geliştirme portu
# Railway: PORT yazma — platform otomatik verir (502 önlemek için)
PORT=8080

# MongoDB — aşağıdaki isimlerden biri yeterli (Railway genelde MONGO_URI veya DATABASE_URL)
MONGO_URI=mongodb://localhost:27017/e-commerce
# MONGO_URL=
# MONGODB_URI=
# DATABASE_URL=

# JWT imzalama anahtarı (giriş, mail doğrulama, şifre sıfırlama token'ları)
JWT_SECRET=your-secret-key

# Resend — HTTP API (Railway SMTP portlarını bloklar, SMTP kullanma)
# SMTP_PASS = Resend API anahtarı (re_...)
# SMTP_FROM = doğrulanmış domain e-postası (örn. noreply@senindomain.com)
SMTP_PASS=re_your-resend-api-key
SMTP_FROM=noreply@yourdomain.com

# Kullanıcının tarayıcıda açtığı frontend adresi (React/Next sitesi).
# Maildeki doğrulama ve şifre sıfırlama linkleri buraya gider — API adresi değil.
# CORS: birden fazla origin (preview/staging) virgülle ayır
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=https://app.example.com,https://preview.example.com

# Log seviyesi: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# İlk owner admin (npm run seed:owner) — sadece local/ilk kurulum
SEED_OWNER_EMAIL=admin@example.com
SEED_OWNER_PASSWORD=your-secure-password

# Supabase Storage — satıcı belgeleri (PDF, logo)
# SUPABASE_URL = sadece proje kök URL (https://xxx.supabase.co) — /rest/v1/ EKLEME
# SUPABASE_SERVICE_ROLE_KEY = service_role key (anon key değil)
# Dashboard: Storage → New bucket → Public önerilir (MVP)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=seller-documents
